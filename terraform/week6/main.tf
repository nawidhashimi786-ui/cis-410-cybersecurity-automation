terraform {
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 5.0"
    }
  }
}

provider "google" {
  project = var.project_id
  region  = var.region
}

resource "google_storage_bucket" "tf_bucket" {
  name          = "${var.project_id}-bucket"
  location      = var.region
  force_destroy = true
}
